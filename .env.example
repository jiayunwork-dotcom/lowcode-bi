# ============================================================
# Lowcode BI Platform - Environment Variables
# Copy this file to .env and update the values as needed
# ============================================================

# PostgreSQL Configuration
POSTGRES_DB=lowcode_bi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# ClickHouse Configuration
CLICKHOUSE_DB=lowcode_bi
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_secure_password_here

# Redis Configuration
REDIS_PASSWORD=your_secure_password_here

# Application Configuration
SPRING_PROFILES_ACTIVE=prod
BI_JWT_SECRET=your_super_secret_key_change_in_production_please
BI_JWT_EXPIRATION=86400000

# Mail Configuration (Optional)
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@example.com
SPRING_MAIL_PASSWORD=your_email_password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Selenium Chrome Configuration
SE_NODE_MAX_SESSIONS=10

# Timezone
TZ=Asia/Shanghai
